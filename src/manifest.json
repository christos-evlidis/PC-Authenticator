{
  "update_url": "https://clients2.google.com/service/update2/crx",
  "manifest_version": 3,
  "name": "Authenticator for PC",
  "version": "1.0.3",
  "description": "A desktop authenticator for saving and managing your 2FA codes",
  "action": {
    "default_popup": "html/index.html"
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://pc-authenticator-pdpy.onrender.com/*"
  ],
  "background": {
    "service_worker": "js/qr-scan/qr-scan-service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'; font-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["css/qr-scan/qr-scan-overlay.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
