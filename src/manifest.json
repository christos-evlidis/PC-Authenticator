{
  "update_url": "https://clients2.google.com/service/update2/crx",
  "manifest_version": 3,
  "name": "Authenticator for PC",
  "version": "1.0.3",
  "description": "A desktop authenticator for saving and managing your 2FA codes",
  "action": {
    "default_popup": "html/index.html"
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://pc-authenticator-pdpy.onrender.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "js/services/scan/worker/worker-index.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/light/icon16.png",
    "48": "icons/light/icon48.png",
    "128": "icons/light/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'; font-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "css/overlay/scan.css",
        "css/base/color.css",
        "css/base/layout.css",
        "js/const/const.scan.js",
        "js/services/scan/content/content-index.js",
        "js/services/scan/content/overlay/create.js",
        "js/services/scan/content/overlay/remove.js",
        "js/services/scan/content/overlay/start.js",
        "js/services/scan/content/overlay/state/store.js",
        "js/services/scan/content/screenshot/load.js",
        "js/services/scan/content/screenshot/capture.js",
        "js/services/scan/content/screenshot/crop.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
